.env

# ── Session Recordings (voices of real people) ───────────────
Session_Sources/Recordings/

# ── Copyrighted D&D Source PDFs ──────────────────────────────
DND_Sources/*.pdf

# ── Obsidian Internal Config ─────────────────────────────────
.obsidian/
.smart-env/
.claude/
.trash/

# ── OS / Editor Junk ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ── Node / Build Artifacts ───────────────────────────────────
node_modules/
package-lock.json
